# Buffer API
# Buffer Settings > API에서 personal key를 발급하고 postsWrite 권한을 포함하세요.
BUFFER_API_KEY=

# Buffer에서 연결된 각 채널 ID를 넣으세요.
# 채널 ID를 모르면 Buffer API Explorer 또는 별도 조회 쿼리로 확인해야 합니다.
BUFFER_CHANNEL_INSTAGRAM=
BUFFER_CHANNEL_THREADS=
BUFFER_CHANNEL_X=

# 기본은 실제 게시하지 않는 dry-run입니다.
DRY_RUN=true

# 예약 기준 시간대와 하루 게시 시간입니다.
TIMEZONE=Asia/Seoul
POST_TIMES=09:00,21:00

# 한 번 실행할 때 며칠치 콘텐츠를 생성/예약할지 정합니다.
CAMPAIGN_DAYS=7

# Instagram 카드뉴스 이미지를 Buffer에 첨부하려면 공개 HTTPS URL이 필요합니다.
# 무료 운영 추천: GitHub Pages
# 1. GitHub Pages를 docs 폴더 기준으로 켭니다.
# 2. 아래 값을 Pages 사이트 루트로 설정합니다.
# 예: https://github-username.github.io/repo-name
# 비워두면 카드뉴스 PNG는 docs/assets에 생성되지만 Buffer에는 이미지가 첨부되지 않습니다.
PUBLIC_ASSET_BASE_URL=

# GitHub Pages가 서빙할 로컬 폴더입니다.
ASSET_EXPORT_DIR=docs

# 실제 Buffer 게시 전 docs/assets 변경분을 자동 commit/push합니다.
PUSH_ASSETS_BEFORE_PUBLISH=true
